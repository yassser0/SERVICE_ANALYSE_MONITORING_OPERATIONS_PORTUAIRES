# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=port_iot_db
POSTGRES_USER=port_admin
POSTGRES_PASSWORD=PortSecure2024!

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=port-iot-data

# ── Simulator ────────────────────────────────────────────────────────────────
EMIT_INTERVAL_SECONDS=3
NUM_SENSORS=20
ANOMALY_PROBABILITY=0.05

# ── Processing Service ────────────────────────────────────────────────────────
TEMP_HIGH_THRESHOLD=85.0
GPS_LAT_MIN=33.0
GPS_LAT_MAX=34.5
GPS_LON_MIN=-8.5
GPS_LON_MAX=-7.0
DATA_LAKE_PATH=/data-lake
LOG_LEVEL=INFO

# ── Anomaly Thresholds ────────────────────────────────────────────────────────
SPEED_LIMIT_KMPH=25.0
BATTERY_LOW_THRESHOLD=15.0
SENSOR_OFFLINE_MINUTES=5

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana2024

# ── Hadoop HDFS ───────────────────────────────────────────────────────────────
HDFS_ENABLED=true
HDFS_URL=http://namenode:9870
HDFS_USER=root
